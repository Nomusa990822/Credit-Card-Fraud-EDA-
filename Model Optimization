    "df[\"trans_hour\"] = df[\"trans_date_trans_time\"].dt.hour\n",
    "df[\"trans_day\"] = df[\"trans_date_trans_time\"].dt.dayofweek\n",
    "df[\"trans_month\"] = df[\"trans_date_trans_time\"].dt.month\n",
    "df[\"age\"] = ((df[\"trans_date_trans_time\"] - df[\"dob\"]).dt.days / 365.25).astype(float)\n",
    "\n",
    "# Retain useful engineered features from Project 3\n",
    "df[\"distance\"] = np.sqrt(\n",
    "    (df[\"lat\"] - df[\"merch_lat\"])**2 +\n",
    "    (df[\"long\"] - df[\"merch_long\"])**2\n",
    ")\n",
    "\n",
    "df[\"is_night\"] = df[\"trans_hour\"].apply(lambda x: 1 if (x >= 22 or x <= 4) else 0)\n",
    "df[\"is_weekend\"] = df[\"trans_day\"].apply(lambda x: 1 if x >= 5 else 0)\n",
    "\n",
    "amount_threshold = df[\"amt\"].quantile(0.95)\n",
    "df[\"high_amount_flag\"] = (df[\"amt\"] > amount_threshold).astype(int)\n",
    "\n",
    "df[\"amt_log\"] = np.log1p(df[\"amt\"])"
